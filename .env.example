# Server
PORT=3000
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://helpdesk:helpdesk@localhost:5432/helpdesk
# E2E tests use a separate database; see server/.env.test (copy credentials to match)

# Auth
BETTER_AUTH_SECRET=change-this-to-a-long-random-string-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# AI
ANTHROPIC_API_KEY=

# Email
# Fill in when an email provider is chosen
EMAIL_PROVIDER_API_KEY=
SUPPORT_EMAIL=support@yourdomain.com
