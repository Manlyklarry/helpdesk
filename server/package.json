{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx prisma generate && bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "start:test": "bun --env-file .env.test src/index.ts",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "better-auth": "^1.6.11",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^24.0.0",
    "prisma": "7.8.0",
    "typescript": "~6.0.0"
  }
}
